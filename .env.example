# ═════════════════════════════════════════════════════════════════════════════
# Transaction Monitor Dashboard — environment configuration
# ═════════════════════════════════════════════════════════════════════════════
# Copy to .env.local for `npm run dev` and to .env.production for production
# deployments. Never commit either to version control.

# ── Required ─────────────────────────────────────────────────────────────────

# Origin of the Autheo TMS backend. The Next.js BFF proxy reads this server-side
# and forwards every authenticated request to <BACKEND_URL>/api/v1/...
#  - http://localhost:8088   →  TMS nginx (recommended local default)
#  - http://localhost:8021   →  TMS FastAPI direct (bypasses nginx; loses TLS)
#  - https://tms.staging…    →  remote deployment
BACKEND_URL=http://localhost:8088

# ── Optional ─────────────────────────────────────────────────────────────────

# Controls HSTS + CSP behaviour in next.config.mjs.
# Set to "production" before deploying.
# NODE_ENV=development

# Surfaced to the client only for diagnostics. The BFF proxy never reads this.
# NEXT_PUBLIC_API_URL=http://localhost:8088

# ── E2E tests (optional) ─────────────────────────────────────────────────────
# When set, Playwright runs the live login + triage specs against a real backend.
# When unset, those specs auto-skip so unit-only CI pipelines stay green.
# E2E_EMAIL=admin@autheo.test
# E2E_PASSWORD=Passw0rd!
